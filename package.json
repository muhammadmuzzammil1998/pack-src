{
  "name": "pack-src",
  "version": "0.1.0",
  "description": "Recursively pack source code directories into clean ZIP archives — fast, smart, and ignore-aware",
  "type": "module",
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "bin": {
    "pack-src": "./dist/cli.js"
  },
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE",
    "CHANGELOG.md"
  ],
  "engines": {
    "node": ">=22"
  },
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "lint": "eslint src tests",
    "lint:fix": "eslint src tests --fix",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "typecheck": "tsc --noEmit",
    "clean": "rimraf dist",
    "prepublishOnly": "pnpm build",
    "release": "changeset publish",
    "version": "changeset version && pnpm install --frozen-lockfile=false",
    "benchmark": "node --experimental-strip-types benchmarks/run.ts"
  },
  "keywords": [
    "zip",
    "archive",
    "pack",
    "source",
    "cli",
    "ignore",
    "gitignore",
    "compress",
    "bundle",
    "snapshot"
  ],
  "author": {
    "name": "Mohammad Muzammil Khan",
    "url": "https://github.com/muhammadmuzzammil1998"
  },
  "license": "MIT",
  "homepage": "https://github.com/muhammadmuzzammil1998/pack-src#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/muhammadmuzzammil1998/pack-src.git"
  },
  "bugs": {
    "url": "https://github.com/muhammadmuzzammil1998/pack-src/issues"
  },
  "dependencies": {
    "archiver": "^7.0.1",
    "chalk": "^5.3.0",
    "commander": "^12.1.0",
    "fast-glob": "^3.3.2",
    "ignore": "^5.3.1",
    "ora": "^8.1.0"
  },
  "devDependencies": {
    "@changesets/cli": "^2.27.7",
    "@eslint/js": "^9.9.0",
    "@types/archiver": "^6.0.2",
    "@types/node": "^22.5.0",
    "@vitest/coverage-v8": "^2.1.1",
    "eslint": "^9.9.0",
    "globals": "^15.9.0",
    "prettier": "^3.3.3",
    "rimraf": "^6.0.1",
    "tsup": "^8.3.0",
    "typescript": "^5.5.4",
    "typescript-eslint": "^8.4.0",
    "vitest": "^2.1.1"
  },
  "packageManager": "pnpm@9.15.0",
  "publishConfig": {
    "access": "public"
  }
}
